{
  "$schema": "https://opencode.ai/config.json",
  // "model": "ollama/glm-4.7-flash-q4_K_M-24b-84k",
  // "model": "openrouter/anthropic/claude-sonnet-4.6",
  "model": "opencode-go/glm-5.1",
  // universal defaults
  "permission": {
    "read": "allow",
    "edit": "ask",
    "bash": {
      "git commit": "deny",
      "git push": "deny",
      "git reset": "deny",
      "git diff": "allow",
      "grep *": "allow",
      "*": "ask"
    },
    "webfetch": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    // This tool is only available when OPENCODE_EXPERIMENTAL_LSP_TOOL=true (or OPENCODE_EXPERIMENTAL=true).
    "lsp": "allow",
    "skill": "ask",
    "todowrite": "allow",
    "todoread": "allow",
    // This tool is only available when using the OpenCode provider or when the OPENCODE_ENABLE_EXA environment variable is set to any truthy value (e.g., true or 1).
    "websearch": "allow",
    "codesearch": "allow",
    "question": "allow",
  },
  "agent": {
    "plan": {
      // opencode go model
      "model": "opencode-go/glm-5.1",
      // https://opencode.ai/docs/agents/#permissions
      "permission": {
        "edit": "deny",
        "task": {
          // Control which subagents an agent can invoke via the Task tool with permission.task. Uses glob patterns for flexible matching.
          "*": "ask",
          // "orchestrator-*": "allow",
          // "code-reviewer": "ask"
        },
        "external_directory": "deny",
        "lsp": "allow",
        "skill": "allow", // TODO fix this
        "doom_loop": "ask",
      }
    },
    "build": {
      "model": "openrouter/anthropic/claude-sonnet-4.6",
      "permission": {
        "edit": "allow"
      }
    },
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama internal",
      "options": {
        "baseURL": "http://192.168.1.182:11434/v1"
      },
      "models": {
        "devstral-small-2-24b-92k": {
          "name": "devstral-small-2-24b-92k",
          "limit": {
            "context": 92000,
            "output": 32000
          }
        },
        "glm-4.7-flash-q4_K_M-24b-84k": {
          "name": "glm-4.7-flash-q4_K_M-24b-84k",
          // "options": {
          //   "thinking": {
          //     // TODO check if this works at all
          //     "type": "enabled",
          //   },
          // },
          "limit": {
            "context": 84000,
            "output": 32000
          }
        },
        "qwen3-coder-30b-84k": {
          "name": "qwen3-coder-30b-84k",
          "limit": {
            "context": 84000,
            "output": 32000
          }
        },
        "qwen3-30b-a3b-94k": {
          "name": "qwen3-30b-a3b-94k",
          "limit": {
            "context": 94000,
            "output": 32000
          }
        },
      }
    }
  },
  "server": {
    "port": 4096,
    "hostname": "0.0.0.0",
    "mdns": true,
    "mdnsDomain": "opencode.local",
    // (other) allowed opencode origins
    "cors": [
      // "http://localhost:5173"
    ]
  },
  "mcp": {
    "dash": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/Kapeli/dash-mcp-server.git",
        "dash-mcp-server"
      ],
      "enabled": true
    }
  }
}
